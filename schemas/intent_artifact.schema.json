{
  "$defs": {
    "ArtifactSource": {
      "additionalProperties": false,
      "properties": {
        "origin": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Origin"
        },
        "source_hash": {
          "title": "Source Hash",
          "type": "string"
        },
        "source_id": {
          "title": "Source Id",
          "type": "string"
        },
        "source_type": {
          "enum": [
            "text",
            "markdown",
            "json",
            "yaml"
          ],
          "title": "Source Type",
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "source_type",
        "source_hash"
      ],
      "title": "ArtifactSource",
      "type": "object"
    },
    "GovernanceFlags": {
      "additionalProperties": false,
      "properties": {
        "ambiguous": {
          "default": false,
          "title": "Ambiguous",
          "type": "boolean"
        },
        "incomplete": {
          "default": false,
          "title": "Incomplete",
          "type": "boolean"
        },
        "requires_human_review": {
          "default": false,
          "title": "Requires Human Review",
          "type": "boolean"
        }
      },
      "title": "GovernanceFlags",
      "type": "object"
    },
    "Lineage": {
      "additionalProperties": false,
      "properties": {
        "compile_run_id": {
          "title": "Compile Run Id",
          "type": "string"
        },
        "parent_artifact_ids": {
          "items": {
            "type": "string"
          },
          "title": "Parent Artifact Ids",
          "type": "array"
        },
        "parent_compile_run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Compile Run Id"
        },
        "parent_source_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Source Hash"
        },
        "pipeline_version": {
          "title": "Pipeline Version",
          "type": "string"
        },
        "source_hash": {
          "title": "Source Hash",
          "type": "string"
        },
        "steps": {
          "items": {
            "$ref": "#/$defs/LineageStep"
          },
          "title": "Steps",
          "type": "array"
        }
      },
      "required": [
        "compile_run_id",
        "pipeline_version",
        "source_hash"
      ],
      "title": "Lineage",
      "type": "object"
    },
    "LineageStep": {
      "additionalProperties": false,
      "properties": {
        "detail": {
          "title": "Detail",
          "type": "string"
        },
        "occurred_at": {
          "format": "date-time",
          "title": "Occurred At",
          "type": "string"
        },
        "stage": {
          "title": "Stage",
          "type": "string"
        }
      },
      "required": [
        "stage",
        "detail"
      ],
      "title": "LineageStep",
      "type": "object"
    },
    "ValidationIssue": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        },
        "severity": {
          "default": "error",
          "enum": [
            "info",
            "warning",
            "error"
          ],
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "ValidationIssue",
      "type": "object"
    },
    "ValidationReport": {
      "additionalProperties": false,
      "properties": {
        "errors": {
          "items": {
            "$ref": "#/$defs/ValidationIssue"
          },
          "title": "Errors",
          "type": "array"
        },
        "generated_at": {
          "format": "date-time",
          "title": "Generated At",
          "type": "string"
        },
        "readiness_status": {
          "default": "warn",
          "enum": [
            "pass",
            "warn",
            "fail"
          ],
          "title": "Readiness Status",
          "type": "string"
        },
        "report_id": {
          "title": "Report Id",
          "type": "string"
        },
        "summary": {
          "default": "",
          "title": "Summary",
          "type": "string"
        },
        "warnings": {
          "items": {
            "$ref": "#/$defs/ValidationIssue"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "report_id"
      ],
      "title": "ValidationReport",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_version": {
      "title": "Artifact Version",
      "type": "string"
    },
    "assumptions": {
      "items": {
        "type": "string"
      },
      "title": "Assumptions",
      "type": "array"
    },
    "authority_context": {
      "default": "",
      "title": "Authority Context",
      "type": "string"
    },
    "compiler_version": {
      "title": "Compiler Version",
      "type": "string"
    },
    "constraints": {
      "items": {
        "type": "string"
      },
      "title": "Constraints",
      "type": "array"
    },
    "context_package": {
      "items": {
        "type": "string"
      },
      "title": "Context Package",
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "dependencies": {
      "items": {
        "type": "string"
      },
      "title": "Dependencies",
      "type": "array"
    },
    "exclusions": {
      "items": {
        "type": "string"
      },
      "title": "Exclusions",
      "type": "array"
    },
    "governance_flags": {
      "$ref": "#/$defs/GovernanceFlags"
    },
    "lineage": {
      "$ref": "#/$defs/Lineage"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "objective": {
      "default": "",
      "title": "Objective",
      "type": "string"
    },
    "output_contract": {
      "items": {
        "type": "string"
      },
      "title": "Output Contract",
      "type": "array"
    },
    "profile": {
      "default": "generic",
      "title": "Profile",
      "type": "string"
    },
    "scope": {
      "items": {
        "type": "string"
      },
      "title": "Scope",
      "type": "array"
    },
    "source": {
      "$ref": "#/$defs/ArtifactSource"
    },
    "success_criteria": {
      "items": {
        "type": "string"
      },
      "title": "Success Criteria",
      "type": "array"
    },
    "target_class": {
      "default": "",
      "title": "Target Class",
      "type": "string"
    },
    "validation": {
      "$ref": "#/$defs/ValidationReport"
    }
  },
  "required": [
    "artifact_id",
    "artifact_version",
    "compiler_version",
    "created_at",
    "source",
    "validation",
    "lineage"
  ],
  "title": "IntentArtifact",
  "type": "object"
}