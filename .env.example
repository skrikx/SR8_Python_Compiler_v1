# SR8 core defaults
SR8_DEFAULT_PROFILE=generic
SR8_EXTRACTION_ADAPTER=rule_based
SR8_INCLUDE_RAW_SOURCE=false
SR8_ASSIST_PROVIDER=
SR8_ASSIST_MODEL=
SR8_ASSIST_FALLBACK_TO_RULE_BASED=true
SR8_WORKSPACE_PATH=.sr8

# OpenAI
SR8_OPENAI_API_KEY=
SR8_OPENAI_MODEL=
SR8_OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI
SR8_AZURE_OPENAI_API_KEY=
SR8_AZURE_OPENAI_ENDPOINT=
SR8_AZURE_OPENAI_DEPLOYMENT=
SR8_AZURE_OPENAI_API_VERSION=2024-10-21

# AWS Bedrock
SR8_AWS_BEDROCK_REGION=us-east-1
SR8_AWS_BEDROCK_MODEL=
SR8_AWS_BEDROCK_PROFILE=
SR8_AWS_BEDROCK_ACCESS_KEY_ID=
SR8_AWS_BEDROCK_SECRET_ACCESS_KEY=
SR8_AWS_BEDROCK_SESSION_TOKEN=
SR8_AWS_BEDROCK_ENDPOINT_URL=
SR8_AWS_BEDROCK_PROBE_RUNTIME=false
SR8_AWS_BEDROCK_PROBE_PROMPT=Respond with the single word ready.
SR8_AWS_BEDROCK_TIMEOUT_SECONDS=30

# Anthropic
SR8_ANTHROPIC_API_KEY=
SR8_ANTHROPIC_MODEL=
SR8_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Gemini
SR8_GEMINI_API_KEY=
SR8_GEMINI_MODEL=
SR8_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Ollama
SR8_OLLAMA_BASE_URL=http://127.0.0.1:11434
SR8_OLLAMA_MODEL=
