SR8_DEFAULT_PROFILE=generic
SR8_COMPILE_MODE=auto
SR8_WORKSPACE_PATH=.sr8

# Optional LLM-assisted extraction. Rules mode does not require these.
SR8_ASSIST_PROVIDER=azure_openai
SR8_ASSIST_MODEL=your-model-name
SR8_ASSIST_FALLBACK_TO_RULE_BASED=true
SR8_SAVE_LLM_TRACE=false

# OpenAI
OPENAI_API_KEY=replace-with-your-openai-key
OPENAI_MODEL=gpt-4.1-mini

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=replace-with-your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=your-deployment

# Anthropic
ANTHROPIC_API_KEY=replace-with-your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-5

# Gemini
GEMINI_API_KEY=replace-with-your-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# AWS Bedrock
AWS_REGION=us-east-1
AWS_PROFILE=your-aws-profile
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
